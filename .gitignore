# =============================================
# IMPORTANT NOTES
# =============================================
# 
# 1. To keep notebook examples in the repo, use:
#    git add --force notebooks/IMDB_Sentiment_Analysis.ipynb
#
# 2. For configuration files with secrets, use:
#    .env.example (with fake values) and .env (ignored)
#
# 3. For small models (< 100 MB), consider Git LFS:
#    git lfs track "*.pkl"
#    git lfs track "*.joblib"
#
# 4. To keep empty folders, use .gitkeep inside them
#
# =============================================

# =============================================
# EXCEPTIONS (files that SHOULD be versioned)
# =============================================

# Example .env file (do not ignore if it's .env.example)
!.env.example
!.env.template

# Example configuration
!config.yaml
!config.example.yaml

# Example notebook (if you want to keep it)
!notebooks/*.ipynb

# Example requirements
!requirements.txt
!requirements-dev.txt

# READMEs and documentation
!README.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md

# Example files
!examples/*.py
!examples/*.ipynb
!scripts/*.py

# Docker
!Dockerfile
!docker-compose.yml

# CI/CD
!.github/
!.github/workflows/*.yml

# =============================================
# END OF .gitignore
# =============================================